+	//! Resolve a credentials provider from a profile's credential_source field
+	std::shared_ptr<Aws::Auth::AWSCredentialsProvider> ResolveCredentialSource(const Aws::Config::Profile &profile) {
+		auto credential_source = profile.GetCredentialSource();
+		if (credential_source == "Ec2InstanceMetadata" || credential_source == "EcsContainer") {
+			return std::make_shared<Aws::Auth::InstanceProfileCredentialsProvider>();
+		} else if (credential_source == "Environment") {
+			return std::make_shared<Aws::Auth::EnvironmentAWSCredentialsProvider>();
+		}
+		return nullptr;
+	}
+
+	//! Resolve source credentials for a profile that uses source_profile or credential_source
+	std::shared_ptr<Aws::Auth::AWSCredentialsProvider> ResolveSourceCredentials(const Aws::Config::Profile &profile) {
+		// credential_source on the profile itself (e.g. credential_source = Ec2InstanceMetadata)
+		auto direct_source = ResolveCredentialSource(profile);
+		if (direct_source) {
+			return direct_source;
+		}
+		// source_profile: resolve that profile's credentials (one level of recursion)
+		auto source_profile_name = profile.GetSourceProfile();
+		if (!source_profile_name.empty()) {
+			auto source_profile = GetProfile(source_profile_name, true);
+			// The source profile might use credential_source
+			auto source_creds = ResolveCredentialSource(source_profile);
+			if (source_creds) {
+				// If source profile also has a role_arn, chain through it
+				if (!source_profile.GetRoleArn().empty()) {
+					Aws::Client::ClientConfiguration clientConfig;
+					if (!SELECTED_CURL_CERT_PATH.empty()) {
+						clientConfig.caFile = SELECTED_CURL_CERT_PATH;
+					}
+					auto sts_client = std::make_shared<Aws::STS::STSClient>(source_creds, clientConfig);
+					auto source_role_arn = source_profile.GetRoleArn();
+					auto source_external_id = source_profile.GetExternalId();
+					return std::make_shared<Aws::Auth::STSAssumeRoleCredentialsProvider>(
+					    source_role_arn, Aws::String(), source_external_id,
+					    Aws::Auth::DEFAULT_CREDS_LOAD_FREQ_SECONDS, sts_client);
+				}
+				return source_creds;
+			}
+			// Fallback: source profile with static credentials
+			return std::make_shared<Aws::Auth::ProfileConfigFileAWSCredentialsProvider>(source_profile_name.c_str());
+		}
+		return nullptr;
+	}
