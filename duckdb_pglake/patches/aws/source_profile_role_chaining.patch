+	//! Resolve source credentials for role chaining via source_profile or credential_source
+	std::shared_ptr<Aws::Auth::AWSCredentialsProvider> ResolveSourceCredentials(const Aws::Config::Profile &profile) {
+		// Check credential_source on the profile itself (accessed via GetValue since no dedicated getter)
+		auto credential_source = profile.GetValue("credential_source");
+		if (!credential_source.empty()) {
+			if (credential_source == "Ec2InstanceMetadata" || credential_source == "EcsContainer") {
+				return std::make_shared<Aws::Auth::InstanceProfileCredentialsProvider>();
+			} else if (credential_source == "Environment") {
+				return std::make_shared<Aws::Auth::EnvironmentAWSCredentialsProvider>();
+			}
+			return nullptr;
+		}
+		// Check source_profile
+		auto source_profile_name = profile.GetSourceProfile();
+		if (!source_profile_name.empty()) {
+			auto source_profile = GetProfile(source_profile_name, true);
+			auto source_creds = ResolveSourceCredentials(source_profile);
+			if (source_creds && !source_profile.GetRoleArn().empty()) {
+				// Source profile needs STS assume-role with its own resolved credentials
+				Aws::Client::ClientConfiguration srcConfig;
+				if (!SELECTED_CURL_CERT_PATH.empty()) {
+					srcConfig.caFile = SELECTED_CURL_CERT_PATH;
+				}
+				auto src_sts = std::make_shared<Aws::STS::STSClient>(source_creds, srcConfig);
+				return std::make_shared<Aws::Auth::STSAssumeRoleCredentialsProvider>(
+				    source_profile.GetRoleArn(), Aws::String(), source_profile.GetExternalId(),
+				    Aws::Auth::DEFAULT_CREDS_LOAD_FREQ_SECONDS, src_sts);
+			}
+			if (source_creds) {
+				return source_creds;
+			}
+			return std::make_shared<Aws::Auth::ProfileConfigFileAWSCredentialsProvider>(source_profile_name.c_str());
+		}
+		return nullptr;
+	}
