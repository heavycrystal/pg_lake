+	std::shared_ptr<Aws::Auth::AWSCredentialsProvider> ResolveSourceCredentials(const Aws::Config::Profile &profile) {
+		auto credential_source = profile.GetValue("credential_source");
+		fprintf(stderr, "[pg_lake_aws] ResolveSourceCredentials: credential_source='%s'\n", credential_source.c_str());
+		if (!credential_source.empty()) {
+			if (credential_source == "Ec2InstanceMetadata" || credential_source == "EcsContainer") {
+				fprintf(stderr, "[pg_lake_aws] Using InstanceProfileCredentialsProvider\n");
+				return std::make_shared<Aws::Auth::InstanceProfileCredentialsProvider>();
+			} else if (credential_source == "Environment") {
+				fprintf(stderr, "[pg_lake_aws] Using EnvironmentAWSCredentialsProvider\n");
+				return std::make_shared<Aws::Auth::EnvironmentAWSCredentialsProvider>();
+			}
+			fprintf(stderr, "[pg_lake_aws] Unknown credential_source, returning nullptr\n");
+			return nullptr;
+		}
+		auto source_profile_name = profile.GetSourceProfile();
+		fprintf(stderr, "[pg_lake_aws] ResolveSourceCredentials: source_profile='%s'\n", source_profile_name.c_str());
+		if (!source_profile_name.empty()) {
+			auto source_profile = GetProfile(source_profile_name, true);
+			auto src_cred_source = source_profile.GetValue("credential_source");
+			fprintf(stderr, "[pg_lake_aws] source profile credential_source='%s', role_arn='%s'\n",
+			        src_cred_source.c_str(), source_profile.GetRoleArn().c_str());
+			std::shared_ptr<Aws::Auth::AWSCredentialsProvider> base_creds;
+			if (src_cred_source == "Ec2InstanceMetadata" || src_cred_source == "EcsContainer") {
+				base_creds = std::make_shared<Aws::Auth::InstanceProfileCredentialsProvider>();
+			} else if (src_cred_source == "Environment") {
+				base_creds = std::make_shared<Aws::Auth::EnvironmentAWSCredentialsProvider>();
+			} else {
+				fprintf(stderr, "[pg_lake_aws] source profile has no credential_source, using ProfileConfigFile\n");
+				base_creds = std::make_shared<Aws::Auth::ProfileConfigFileAWSCredentialsProvider>(source_profile_name.c_str());
+			}
+			if (!source_profile.GetRoleArn().empty() && base_creds) {
+				fprintf(stderr, "[pg_lake_aws] Creating STS client for source profile role assumption\n");
+				Aws::Client::ClientConfiguration srcConfig;
+				if (!SELECTED_CURL_CERT_PATH.empty()) {
+					srcConfig.caFile = SELECTED_CURL_CERT_PATH;
+				}
+				auto src_sts = std::make_shared<Aws::STS::STSClient>(base_creds, srcConfig);
+				auto provider = std::make_shared<Aws::Auth::STSAssumeRoleCredentialsProvider>(
+				    source_profile.GetRoleArn(), Aws::String(), source_profile.GetExternalId(),
+				    Aws::Auth::DEFAULT_CREDS_LOAD_FREQ_SECONDS, src_sts);
+				auto test_creds = provider->GetAWSCredentials();
+				fprintf(stderr, "[pg_lake_aws] source profile creds empty=%d\n", test_creds.IsEmpty());
+				return provider;
+			}
+			return base_creds;
+		}
+		fprintf(stderr, "[pg_lake_aws] No source_profile or credential_source found\n");
+		return nullptr;
+	}
